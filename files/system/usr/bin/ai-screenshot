#!/usr/bin/env bash
set -euo pipefail

mode="${1:-area}"

dir="$HOME/Pictures/Screenshots"
mkdir -p "$dir"

file="$dir/screenshot-$(date +%Y%m%d-%H%M%S).png"

case "$mode" in
  full)
    grim "$file"
    ;;
  area|selection)
    geom="$(slurp)" || exit 0
    [ -z "$geom" ] && exit 0
    grim -g "$geom" "$file"
    ;;
  *)
    echo "Usage: ai-screenshot [area|full]" >&2
    exit 1
    ;;
esac

wl-copy < "$file" 2>/dev/null || true
notify-send "Screenshot" "Salvato e copiato negli appunti: $(basename "$file")" 2>/dev/null || true

echo "$file"
