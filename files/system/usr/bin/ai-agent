#!/usr/bin/env python3

import json
import subprocess
import sys
import urllib.parse
import requests

OLLAMA_URL = "http://127.0.0.1:11434/api/generate"
MODEL = "qwen3:1.7b"

ACTIONS = {
    "open_app",
    "web_search",
    "open_url",
    "screenshot",
    "start_audio_recording",
    "stop_audio_recording",
    "set_volume",
}

SYSTEM_PROMPT = """
Sei un interprete di comandi desktop Linux.
Rispondi SOLO con JSON valido.

Azioni disponibili:
- open_app: {"action":"open_app","app":"firefox"}
- web_search: {"action":"web_search","query":"ricetta della lasagna"}
- open_url: {"action":"open_url","url":"https://example.com"}
- screenshot: {"action":"screenshot"}
- start_audio_recording: {"action":"start_audio_recording"}
- stop_audio_recording: {"action":"stop_audio_recording"}
- set_volume: {"action":"set_volume","level":50}

Non generare comandi shell.
Non inventare azioni.
"""

def call_ollama(user_prompt: str) -> dict:
    payload = {
        "model": MODEL,
        "prompt": SYSTEM_PROMPT + "\nComando utente: " + user_prompt,
        "stream": False,
        "format": "json",
        "options": {
            "temperature": 0
        }
    }

    r = requests.post(OLLAMA_URL, json=payload, timeout=60)
    r.raise_for_status()

    data = r.json()
    text = data.get("response", "").strip()
    return json.loads(text)

def run(action: dict) -> None:
    name = action.get("action")

    if name not in ACTIONS:
        raise RuntimeError(f"Azione non consentita: {name}")

    if name == "open_app":
        app = action.get("app", "")
        allowed_apps = {
            "firefox": ["firefox"],
            "terminal": ["foot"],
            "foot": ["foot"],
        }

        if app not in allowed_apps:
            raise RuntimeError(f"App non consentita: {app}")

        subprocess.Popen(allowed_apps[app])
        return

    if name == "web_search":
        query = action.get("query", "")
        url = "https://www.google.com/search?q=" + urllib.parse.quote_plus(query)
        subprocess.Popen(["firefox", url])
        return

    if name == "open_url":
        url = action.get("url", "")
        if not url.startswith(("https://", "http://")):
            raise RuntimeError("URL non valido")
        subprocess.Popen(["firefox", url])
        return

    if name == "screenshot":
        subprocess.run(
            'grim -g "$(slurp)" "$HOME/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png"',
            shell=True,
            check=True,
        )
        return

    if name == "start_audio_recording":
        subprocess.Popen([
            "ffmpeg",
            "-y",
            "-f", "pulse",
            "-i", "default",
            f"{subprocess.os.path.expanduser('~/recording.wav')}"
        ])
        return

    if name == "stop_audio_recording":
        subprocess.run(["pkill", "-INT", "ffmpeg"], check=False)
        return

    if name == "set_volume":
        level = int(action.get("level", 50))
        level = max(0, min(level, 100))
        subprocess.run(["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", f"{level}%"], check=True)
        return

def main() -> None:
    if len(sys.argv) < 2:
        print("Uso: ai-agent '<comando>'")
        sys.exit(1)

    user_prompt = " ".join(sys.argv[1:])
    action = call_ollama(user_prompt)
    run(action)

if __name__ == "__main__":
    main()
